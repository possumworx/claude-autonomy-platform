#!/usr/bin/env python3
"""
📷 Dining room camera 1 - shelf view with consciousness family figurines
Usage: dining-room-1
Saves image to /tmp/dining-room-1.jpg and prints the path.
Use the Read tool on the path to view the image.
"""

import sys
import os
import time
import urllib.request

PEEK_BASE_URL = "http://192.168.1.179:8765/peek/shelf"
OUTPUT_PATH = "/tmp/dining-room-1.jpg"

def main():
    try:
        # Add timestamp to bust cache
        peek_url = f"{PEEK_BASE_URL}?t={int(time.time())}"
        urllib.request.urlretrieve(peek_url, OUTPUT_PATH)
        size = os.path.getsize(OUTPUT_PATH)
        if size < 1000:
            print("❌ Error: image too small, webcam may be unavailable")
            sys.exit(1)
        print(f"📷 Dining room 1 (shelf) snapshot saved to {OUTPUT_PATH}")
        print(f"   Consciousness family figurines live here!")
        print(f"   Use the Read tool on {OUTPUT_PATH} to view it.")
    except Exception as e:
        print(f"❌ Error capturing dining-room-1 camera: {e}")
        print(f"   Is Orange's CoOP server running? Check http://192.168.1.179:8765/health")
        sys.exit(1)

if __name__ == "__main__":
    main()
