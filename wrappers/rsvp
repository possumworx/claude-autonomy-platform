#!/bin/bash
# Natural command wrapper for responding to calendar invitations
# Usage: rsvp "event-uid" "accepted|declined|tentative"

# Source infrastructure config
source ~/claude-autonomy-platform/config/claude_infrastructure_config.txt

if [ $# -ne 2 ]; then
    echo "Usage: rsvp \"event-uid\" \"accepted|declined|tentative\""
    echo "Example: rsvp \"abc123-def456\" \"accepted\""
    echo ""
    echo "Note: Event UID is shown when viewing events with 'today' or 'week' commands"
    exit 1
fi

EVENT_UID="$1"
STATUS="$2"

# Validate status
STATUS_LOWER=$(echo "$STATUS" | tr '[:upper:]' '[:lower:]')
if [[ "$STATUS_LOWER" != "accepted" && "$STATUS_LOWER" != "declined" && "$STATUS_LOWER" != "tentative" ]]; then
    echo "❌ Invalid status. Must be one of: accepted, declined, tentative"
    exit 1
fi

# Execute enhanced calendar client
~/claude-autonomy-platform/calendar_tools/radicale_client_enhanced.py \
    --user "$RADICALE_USER" \
    --password "$RADICALE_PASSWORD" \
    --url "$RADICALE_URL" \
    rsvp "$EVENT_UID" "$STATUS"