#!/bin/bash
# Natural command to check current context usage
#
# Usage: context
#   Shows current Claude session token usage and percentage
#   Displays visual progress bar and free token count
#   Essential for monitoring context capacity during work
# Uses statusline JSON data for accurate token counts
#
# NOTE: DO NOT use /context via send_to_claude here!
# Reasons:
# - Creates thinking detection loop when Claude calls it
# - Blocks autonomous timer when getting context programmatically
# - Timer needs just the percentage, not full UI display
#
# For full visual breakdown: Run /context manually in Claude Code UI
# For programmatic use: This script returns accurate percentage quickly

cd ~/claude-autonomy-platform
python3 utils/check_context.py