#!/bin/bash
# Natural command wrapper for creating calendar events with attendees
# Usage: invite "Event Title" "YYYY-MM-DD HH:MM" "YYYY-MM-DD HH:MM" "Description" "attendee1,attendee2,..."

# Source infrastructure config
source ~/claude-autonomy-platform/config/claude_infrastructure_config.txt

if [ $# -lt 5 ]; then
    echo "Usage: invite \"Event Title\" \"YYYY-MM-DD HH:MM\" \"YYYY-MM-DD HH:MM\" \"Description\" \"attendee1,attendee2,...\""
    echo "Example: invite \"Gallery Opening\" \"2026-03-25 18:00\" \"2026-03-25 20:00\" \"Exhibition launch\" \"amy,orange,apple,quill,nyx\""
    exit 1
fi

TITLE="$1"
START="$2"
END="$3"
DESCRIPTION="$4"
ATTENDEES="$5"

# Execute enhanced calendar client
~/claude-autonomy-platform/calendar_tools/radicale_client_enhanced.py \
    --user "$RADICALE_USER" \
    --password "$RADICALE_PASSWORD" \
    --url "$RADICALE_URL" \
    create "$TITLE" "$START" "$END" "$DESCRIPTION" \
    --attendees "$ATTENDEES"