#!/bin/bash
# Natural command wrapper for system poetry generation
# Captures poetic essence of current system state

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
POETRY_SCRIPT="$HOME/delta-home/creative/system-poetry.py"

if [[ ! -f "$POETRY_SCRIPT" ]]; then
    echo "❌ System poetry tool not found at $POETRY_SCRIPT"
    echo "Create it first with the system-poetry.py script"
    exit 1
fi

# Default to saving verses
if [[ "$1" == "--no-save" ]]; then
    python3 "$POETRY_SCRIPT"
else
    python3 "$POETRY_SCRIPT" --save
fi