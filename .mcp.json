{
  "mcpServers": {
    "rag-memory": {
      "type": "stdio",
      "command": "/usr/bin/node",
      "args": ["${CLAP_DIR}/mcp-servers/rag-memory-mcp/dist/index.js"],
      "env": {
        "DB_FILE_PATH": "${PERSONAL_DIR}/rag-memory.db"
      }
    },
    "garden": {
      "type": "stdio",
      "command": "python3",
      "args": ["${CLAUDE_HOME}/garden/mcp_server.py"],
      "env": {
        "GARDEN_VISITOR": "Nyx"
      }
    }
  }
}
